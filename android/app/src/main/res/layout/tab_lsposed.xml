<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a1a"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LSPosed/Xposed Hooks"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BlindSpot includes the following Xposed hooks for app behavior modification"
            android:textSize="12sp"
            android:textColor="#CCCCCC"
            android:gravity="center"
            android:paddingBottom="24dp" />

        <!-- Hook 1: Morphe -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#2a2a2a"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/icon_morphe"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="16dp"
                android:src="@android:drawable/ic_menu_gallery" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Morphe Content Watchdog"
                        android:textSize="18sp"
                        android:textColor="#4CAF50"
                        android:textStyle="bold"
                        android:paddingBottom="4dp" />
                    
                    <ImageView
                        android:id="@+id/info_morphe"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_info_details"
                        android:layout_marginEnd="8dp"
                        android:tint="#888888"
                        android:contentDescription="Hook Info" />

                    <Switch
                        android:id="@+id/switch_hook_morphe"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Package: app.morphe.android.youtube"
                    android:textSize="11sp"
                    android:textColor="#888888"
                    android:paddingBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Content filtering and parental control"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:lineSpacingMultiplier="1.2" />

                <!-- Pending Action Area -->
                <LinearLayout
                    android:id="@+id/pending_morphe_area"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#3a3a3a"
                    android:padding="8dp"
                    android:layout_marginTop="8dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/pending_morphe_timer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="⏱️ Hook change pending: 5m 0s"
                        android:textSize="12sp"
                        android:textColor="#FFA726"
                        android:paddingBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/pending_morphe_apply"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Apply Now"
                            android:textSize="12sp"
                            android:layout_marginEnd="4dp"
                            android:visibility="gone" />

                        <Button
                            android:id="@+id/pending_morphe_cancel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Cancel"
                            android:textSize="12sp"
                            android:layout_marginStart="4dp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Hook 2: Messenger -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#2a2a2a"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/icon_messenger"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="16dp"
                android:src="@android:drawable/ic_menu_gallery" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Messenger Ghost-Touch Protection"
                        android:textSize="18sp"
                        android:textColor="#4CAF50"
                        android:textStyle="bold"
                        android:paddingBottom="4dp" />
                    
                    <ImageView
                        android:id="@+id/info_messenger"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_info_details"
                        android:layout_marginEnd="8dp"
                        android:tint="#888888"
                        android:contentDescription="Hook Info" />

                    <Switch
                        android:id="@+id/switch_hook_messenger"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Package: com.facebook.orca"
                    android:textSize="11sp"
                    android:textColor="#888888"
                    android:paddingBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Blocks Meta AI search and unwanted UI"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:lineSpacingMultiplier="1.2" />

                <!-- Pending Action Area -->
                <LinearLayout
                    android:id="@+id/pending_messenger_area"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#3a3a3a"
                    android:padding="8dp"
                    android:layout_marginTop="8dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/pending_messenger_timer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="⏱️ Hook change pending: 5m 0s"
                        android:textSize="12sp"
                        android:textColor="#FFA726"
                        android:paddingBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/pending_messenger_apply"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Apply Now"
                            android:textSize="12sp"
                            android:layout_marginEnd="4dp"
                            android:visibility="gone" />

                        <Button
                            android:id="@+id/pending_messenger_cancel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Cancel"
                            android:textSize="12sp"
                            android:layout_marginStart="4dp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Hook 3: Facebook -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#2a2a2a"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/icon_facebook"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="16dp"
                android:src="@android:drawable/ic_menu_gallery" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Facebook Scroll-Lock &amp; Feed Blocker"
                        android:textSize="18sp"
                        android:textColor="#4CAF50"
                        android:textStyle="bold"
                        android:paddingBottom="4dp" />
                    
                    <ImageView
                        android:id="@+id/info_facebook"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_info_details"
                        android:layout_marginEnd="8dp"
                        android:tint="#888888"
                        android:contentDescription="Hook Info" />

                    <Switch
                        android:id="@+id/switch_hook_facebook"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Package: com.facebook.katana"
                    android:textSize="11sp"
                    android:textColor="#888888"
                    android:paddingBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Prevents doom-scrolling and feed browsing"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:lineSpacingMultiplier="1.2" />

                <!-- Pending Action Area -->
                <LinearLayout
                    android:id="@+id/pending_facebook_area"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#3a3a3a"
                    android:padding="8dp"
                    android:layout_marginTop="8dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/pending_facebook_timer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="⏱️ Hook change pending: 5m 0s"
                        android:textSize="12sp"
                        android:textColor="#FFA726"
                        android:paddingBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/pending_facebook_apply"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Apply Now"
                            android:textSize="12sp"
                            android:layout_marginEnd="4dp"
                            android:visibility="gone" />

                        <Button
                            android:id="@+id/pending_facebook_cancel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Cancel"
                            android:textSize="12sp"
                            android:layout_marginStart="4dp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Hook 4: Edge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#2a2a2a"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/icon_edge"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="16dp"
                android:src="@android:drawable/ic_menu_gallery" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Edge Preview Page Blocker"
                        android:textSize="18sp"
                        android:textColor="#4CAF50"
                        android:textStyle="bold"
                        android:paddingBottom="4dp" />
                    
                    <ImageView
                        android:id="@+id/info_edge"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_info_details"
                        android:layout_marginEnd="8dp"
                        android:tint="#888888"
                        android:contentDescription="Hook Info" />

                    <Switch
                        android:id="@+id/switch_hook_edge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Package: com.microsoft.emmx, com.microsoft.msedge"
                    android:textSize="11sp"
                    android:textColor="#888888"
                    android:paddingBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Disables preview page options in context menus"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:lineSpacingMultiplier="1.2" />

                <!-- Pending Action Area -->
                <LinearLayout
                    android:id="@+id/pending_edge_area"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#3a3a3a"
                    android:padding="8dp"
                    android:layout_marginTop="8dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/pending_edge_timer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="⏱️ Hook change pending: 5m 0s"
                        android:textSize="12sp"
                        android:textColor="#FFA726"
                        android:paddingBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/pending_edge_apply"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Apply Now"
                            android:textSize="12sp"
                            android:layout_marginEnd="4dp"
                            android:visibility="gone" />

                        <Button
                            android:id="@+id/pending_edge_cancel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Cancel"
                            android:textSize="12sp"
                            android:layout_marginStart="4dp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Installation Note -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#3a3a3a"
            android:padding="16dp"
            android:layout_marginTop="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚙️ Installation Requirements"
                android:textSize="16sp"
                android:textColor="#FFA500"
                android:textStyle="bold"
                android:paddingBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• LSPosed or EdXposed framework must be installed\n• Enable BlindSpot module in LSPosed Manager\n• Select target apps (Morphe, Messenger, Facebook, Edge) in module scope\n• Force stop target apps for hooks to take effect\n• Hooks are defined in MorpheHook.java, MessengerHook.java, FacebookHook.java, and EdgeHook.java"
                android:textSize="14sp"
                android:textColor="#CCCCCC"
                android:lineSpacingMultiplier="1.3" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
