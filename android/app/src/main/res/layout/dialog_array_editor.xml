<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="?android:attr/colorBackground">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="✏️ Array Editor"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_gravity="center_vertical" />

        <Button
            android:id="@+id/btn_editor_toggle_sep"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lines"
            android:minWidth="0dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginEnd="8dp"
            style="?android:attr/buttonBarButtonStyle" />

        <Button
            android:id="@+id/btn_editor_sort"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sort A-Z"
            android:minWidth="0dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            style="?android:attr/buttonBarButtonStyle" />

    </LinearLayout>

    <!-- Stats Bar -->
    <TextView
        android:id="@+id/editor_stats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="0 items"
        android:textSize="12sp"
        android:textColor="?android:attr/textColorSecondary"
        android:layout_marginBottom="8dp" />

    <!-- Editor -->
    <EditText
        android:id="@+id/editor_text"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:hint="Enter items (one per line or comma-separated)..."
        android:textColorHint="?android:attr/textColorHint"
        android:textColor="?android:attr/textColorPrimary"
        android:background="?android:attr/selectableItemBackground"
        android:gravity="top|start"
        android:inputType="textMultiLine"
        android:padding="12dp"
        android:scrollbars="vertical"
        android:fontFamily="monospace" />

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp">

        <Button
            android:id="@+id/btn_editor_cancel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cancel"
            android:layout_marginEnd="8dp"
            style="?android:attr/buttonBarButtonStyle" />

        <Button
            android:id="@+id/btn_editor_save"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="✅ Save" />

    </LinearLayout>

</LinearLayout>
