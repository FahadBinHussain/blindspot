<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="App Protection Manager"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="?android:attr/textColorPrimary"
        android:paddingBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Block = Suspend app + Protect data\nProtect = Prevent uninstall + Protect data"
        android:textSize="12sp"
        android:textColor="?android:attr/textColorSecondary"
        android:paddingBottom="8dp" />

    <Button
        android:id="@+id/btn_unhide_all"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Unhide All Hidden Apps"
        android:textAllCaps="false"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/search_apps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="🔍 Search apps..."
        android:textColorHint="?android:attr/textColorHint"
        android:textColor="?android:attr/textColorPrimary"
        android:padding="12dp"
        android:elevation="8dp"
        android:background="?android:attr/colorBackground" />

    <ListView
        android:id="@+id/apps_protection_list"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="8dp" />

</LinearLayout>
