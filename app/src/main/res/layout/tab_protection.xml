<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="App Protection &amp; Blocking"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Manage app blocking and protection settings"
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginBottom="32dp"
        android:gravity="center" />

    <Button
        android:id="@+id/btn_app_protection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Manage App Protection &amp; Blocking"
        android:textSize="16sp"
        android:padding="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Block = Suspend app (grayed) • Protect = Prevent uninstall + data clear"
        android:textSize="12sp"
        android:textColor="#666666"
        android:layout_marginTop="16dp"
        android:gravity="center" />

</LinearLayout>
